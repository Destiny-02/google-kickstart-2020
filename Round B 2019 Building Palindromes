  public static boolean checkMakesPalindrome(String alphabet) {
    // can generate a palindrome if there is an even number of every letter (even total number of letters)
    // can generate a palindrome if there is an even number of every letter except one letter (odd total number of letters)

    // convert to ArrayList<Character>

    boolean makesPalindrome = true;

    // convert to sorted array of sorted characters
    char[] charArray = alphabet.toCharArray();
    Arrays.sort(charArray); 
    

    if (charArray.length % 2 == 0) {
      // check for even number of every letter
      for (int c=0; c<charArray.length; c+=2) {
        if (charArray[c] != charArray[c+1]) {
          makesPalindrome = false;
        }
      }
    } else {
      // remove odd letter 
      // check for even number of every letter 
      int numOdd = 0;
      for (int c=0; c<charArray.length-1; c+=2) {
        if (charArray[c] != charArray[c+1]) {
          if (numOdd >= 1) {
            makesPalindrome = false;
          }
          numOdd += 1;
          c--;
        }

      }
    }


    return makesPalindrome;
  }

